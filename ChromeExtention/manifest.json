{
  "manifest_version": 3,
  "name": "Browser Workflow Agent",
  "version": "1.0.0",
  "description": "AI browser workflow assistant",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ]
}